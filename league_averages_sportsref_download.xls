<html xmlns:o="urn:schemas-microsoft-com:office:office" xmlns:x="urn:schemas-microsoft-com:office:excel" xmlns="http://www.w3.org/TR/REC-html40"><head><!--[if gte mso 9]><xml><x:ExcelWorkbook><x:ExcelWorksheets><x:ExcelWorksheet><x:Name>Worksheet</x:Name><x:WorksheetOptions><x:DisplayGridlines/></x:WorksheetOptions></x:ExcelWorksheet></x:ExcelWorksheets></x:ExcelWorkbook></xml><![endif]--></head><body><table>
    
    

   
   <thead>      
      <tr>
         <th aria-label="Year" data-stat="year_ID" scope="col" class=" poptip sort_default_asc show_partial_when_sorting left" data-tip="A Star indicates an all-star that season.&lt;br&gt;A Ring indicates the player appeared in WS for winning team.">Year</th>
         <th aria-label="Tms" data-stat="teams" scope="col" class=" poptip center">Tms</th>
         <th aria-label="#Bat" data-stat="batters_used" scope="col" class=" poptip center" data-tip="&lt;strong&gt;Number of Players used in Games&lt;/strong&gt;">#Bat</th>
         <th aria-label="BatAge" data-stat="age_bat" scope="col" class=" poptip sort_default_asc center" data-tip="&lt;strong&gt;Batters&amp;#x2019; average age&lt;/strong&gt;&lt;br&gt;Weighted by AB + Games Played">BatAge</th>
         <th aria-label="Runs Scored/Game" data-stat="runs_per_game" scope="col" class=" poptip center" data-tip="Runs Scored Per Game">R/G</th>
         <th aria-label="Games Played" data-stat="G" scope="col" class=" poptip center" data-tip="Games Played or Pitched">G</th>
         <th aria-label="Plate Appearances" data-stat="PA" scope="col" class=" poptip center" data-tip="&lt;strong&gt;Plate Appearances&lt;/strong&gt;&lt;br&gt;When available, we use actual plate appearances from play-by-play game accounts&lt;br&gt;Otherwise estimated using AB + BB + HBP + SF + SH,&lt;br&gt;which excludes catcher interferences.&lt;br&gt;When &lt;span class=tooltip&gt;this color&lt;/span&gt; click for a summary of each PA.">PA</th>
         <th aria-label="At Bats" data-stat="AB" scope="col" class=" poptip center" data-tip="At Bats">AB</th>
         <th aria-label="Runs Scored" data-stat="R" scope="col" class=" poptip center" data-tip="Runs Scored/Allowed">R</th>
         <th aria-label="Hits" data-stat="H" scope="col" class=" poptip center" data-tip="Hits/Hits Allowed">H</th>
         <th aria-label="Singles" data-stat="1B" scope="col" class=" poptip center" data-tip="Singles Hit/Allowed">1B</th>
         <th aria-label="Doubles" data-stat="2B" scope="col" class=" poptip center" data-tip="Doubles Hit/Allowed">2B</th>
         <th aria-label="Triples" data-stat="3B" scope="col" class=" poptip center" data-tip="Triples Hit/Allowed">3B</th>
         <th aria-label="Home Runs" data-stat="HR" scope="col" class=" poptip center" data-tip="Home Runs Hit/Allowed">HR</th>
         <th aria-label="Runs Batted In" data-stat="RBI" scope="col" class=" poptip center" data-tip="Runs Batted In">RBI</th>
         <th aria-label="Stolen Bases" data-stat="SB" scope="col" class=" poptip center" data-tip="Stolen Bases">SB</th>
         <th aria-label="Caught Stealing" data-stat="CS" scope="col" class=" poptip center" data-tip="Caught Stealing">CS</th>
         <th aria-label="Bases on Balls" data-stat="BB" scope="col" class=" poptip center" data-tip="Bases on Balls/Walks">BB</th>
         <th aria-label="Strikeouts" data-stat="SO" scope="col" class=" poptip center" data-tip="Strikeouts">SO</th>
         <th aria-label="Batting Average" data-stat="batting_avg" scope="col" class=" poptip hide_non_quals center" data-tip="&lt;strong&gt;Hits/At Bats&lt;/strong&gt;&lt;br&gt;For recent years, leaders need 3.1 PA&lt;br&gt;per team game played&lt;br&gt;Bold indicates either highest BA using current stats&lt;br&gt;or awarded title at end of year." data-filter="1" data-name="Batting Average">BA</th>
         <th aria-label="On-Base%" data-stat="onbase_perc" scope="col" class=" poptip hide_non_quals center" data-tip="&lt;strong&gt;(H + BB + HBP)/(At Bats + BB + HBP + SF)&lt;/strong&gt;&lt;br&gt;For recent years, leaders need 3.1 PA&lt;br&gt;per team game played" data-filter="1" data-name="On-Base%">OBP</th>
         <th aria-label="Slugging %" data-stat="slugging_perc" scope="col" class=" poptip hide_non_quals center" data-tip="&lt;strong&gt;Total Bases/At Bats or &lt;br&gt;(1B + 2*2B + 3*3B + 4*HR)/AB&lt;/strong&gt;&lt;br&gt;For recent years, leaders need 3.1 PA&lt;br&gt;per team game played" data-filter="1" data-name="Slugging %">SLG</th>
         <th aria-label="On-Base Plus Slugging" data-stat="onbase_plus_slugging" scope="col" class=" poptip hide_non_quals center" data-tip="&lt;strong&gt;On-Base + Slugging Percentages &lt;/strong&gt;&lt;br&gt;For recent years, leaders need 3.1 PA&lt;br&gt;per team game played" data-filter="1" data-name="On-Base Plus Slugging">OPS</th>
         <th aria-label="Total Bases" data-stat="TB" scope="col" class=" poptip center" data-tip="&lt;strong&gt;Total Bases&lt;/strong&gt;&lt;br&gt;Singles + 2 x Doubles + 3 x Triples + 4 x Home Runs.">TB</th>
         <th aria-label="Double Plays Grounded Into" data-stat="GIDP" scope="col" class=" poptip center" data-tip="&lt;strong&gt;Double Plays Grounded Into&lt;/strong&gt;&lt;br&gt;Only includes standard 6-4-3, 4-3, etc. double plays.&lt;br&gt;First tracked in 1933.&lt;br&gt;For gamelogs only in seasons we have play-by-play, we include triple plays as well.&lt;br&gt;All official seasonal totals do not include GITP's.">GDP</th>
         <th aria-label="Hit By Pitch" data-stat="HBP" scope="col" class=" poptip center" data-tip="Times Hit by a Pitch.">HBP</th>
         <th aria-label="Sacrifice Hits" data-stat="SH" scope="col" class=" poptip center" data-tip="Sacrifice Hits (Sacrifice Bunts)">SH</th>
         <th aria-label="Sacrifice Flies" data-stat="SF" scope="col" class=" poptip center" data-tip="&lt;strong&gt;Sacrifice Flies&lt;/strong&gt;&lt;br&gt;First tracked in 1954.">SF</th>
         <th aria-label="Intentional Bases on Balls" data-stat="IBB" scope="col" class=" poptip center" data-tip="&lt;strong&gt;Intentional Bases on Balls&lt;/strong&gt;&lt;br&gt;First tracked in 1955.">IBB</th>
         <th aria-label="Balls In Play" data-stat="bip" scope="col" class=" poptip center" data-tip="&lt;strong&gt;# Balls in Plays&lt;/strong&gt;At Bats - SO - HR + Sac Flies&lt;br&gt;This is the number of balls the defense must deal with.">BIP</th>
      </tr>
      </thead>
<tbody><tr data-row="0"><th scope="row" class="left " data-stat="year_ID">2026</th><td class="left " data-stat="teams">30</td><td class="right " data-stat="batters_used">625</td><td class="right " data-stat="age_bat">28.0</td><td class="right " data-stat="runs_per_game">4.49</td><td class="right " data-stat="G">2400</td><td class="right " data-stat="PA">37.88</td><td class="right " data-stat="AB">33.59</td><td class="right " data-stat="R">4.49</td><td class="right " data-stat="H">8.17</td><td class="right " data-stat="1B">5.32</td><td class="right " data-stat="2B">1.58</td><td class="right " data-stat="3B">0.13</td><td class="right " data-stat="HR">1.14</td><td class="right " data-stat="RBI">4.30</td><td class="right " data-stat="SB">0.69</td><td class="right " data-stat="CS">0.21</td><td class="right " data-stat="BB">3.43</td><td class="right " data-stat="SO">8.37</td><td class="right " data-stat="batting_avg">.243</td><td class="right " data-stat="onbase_perc">.319</td><td class="right " data-stat="slugging_perc">.400</td><td class="right " data-stat="onbase_plus_slugging">.719</td><td class="right " data-stat="TB">13.43</td><td class="right " data-stat="GIDP">0.63</td><td class="right " data-stat="HBP">0.44</td><td class="right " data-stat="SH">0.13</td><td class="right " data-stat="SF">0.27</td><td class="right " data-stat="IBB">0.10</td><td class="right " data-stat="bip">24.35</td></tr>
